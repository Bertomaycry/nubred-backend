// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// User model - Main user entity with authentication and profile management
model User {
  id                         String    @id @default(auto()) @map("_id") @db.ObjectId
  firstName                  String
  lastName                   String?
  email                      String    @unique
  phoneNumber                String    @unique
  password                   String
  supabaseUserId             String?   @unique
  role                       String    @default("user") // enum: user, admin
  refreshToken               String?
  accessToken                String?

  // Ban system - nested object
  ban_is_banned              Boolean   @default(false)
  ban_type                   String?
  ban_reason                 String?
  ban_period                 Int?

  // Account status flags
  account_created            Boolean   @default(false)
  is_unregistered            Boolean   @default(false)
  unregister_requested       Boolean   @default(false)
  unregister_scheduled_at    DateTime?
  is_account_created_skipped Boolean   @default(false)
  is_onboarded               Boolean   @default(false)

  // Profile polymorphism
  profile_type               String?   // enum: company, consultant
  profileId                  String?   @db.ObjectId

  // Timestamps
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  // Relations
  companyProfile             CompanyProfile?
  consultantProfile          ConsultantProfile?
  chatHistory                ChatHistory[]

  @@map("users")
}

// Company Profile model - Extends User with company-specific information
model CompanyProfile {
  id                         String    @id @default(auto()) @map("_id") @db.ObjectId
  userId                     String    @unique @db.ObjectId

  // Company information
  legal_company_name         String
  country_of_incorporation   String
  vat_number                 String?
  company_email              String
  use_signup_email           Boolean   @default(false)
  description                String?

  // Nested location object
  location_address           String?
  location_postal_code       String?
  location_country           String?

  // Nested legal representative object
  legal_rep_first_name       String?
  legal_rep_last_name        String?
  legal_rep_email            String?
  legal_rep_phone_number     String?
  legal_rep_whatsapp_number  String?

  // Flags
  use_signup_info            Boolean   @default(false)
  use_signup_phone           Boolean   @default(false)

  // Timestamps
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  // Relations
  user                       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("companies")
}

// Consultant Profile model - Extends User with consultant-specific information
model ConsultantProfile {
  id                         String    @id @default(auto()) @map("_id") @db.ObjectId
  userId                     String    @unique @db.ObjectId

  // Consultant information
  consultant_name            String
  consultant_email           String
  use_signup_email           Boolean   @default(false)
  description                String?

  // Nested location object
  location_address           String?
  location_postal_code       String?
  location_country           String?

  // Nested personal info object
  personal_info_first_name   String?
  personal_info_last_name    String?
  personal_info_email        String?
  personal_info_phone_number String?

  // Flags
  use_signup_info            Boolean   @default(false)
  use_signup_phone           Boolean   @default(false)

  // Timestamps
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  // Relations
  user                       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("consultants")
}

// Inquiry model - Contact form submissions from public users
model Inquiry {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String
  contact   String
  message   String

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("inquiries")
}

// ChatHistory model - Stores chat messages for users
model ChatHistory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  message   String

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("chats")
}
